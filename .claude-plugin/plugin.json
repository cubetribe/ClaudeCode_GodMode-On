{
  "name": "cc-godmode",
  "version": "7.1.0",
  "description": "Self-orchestrating multi-agent development system powered by Claude Fable 5 — 15 agents (8 core + 1 security gate + 6 department), Smart Routing default, token-efficient subagents, risk-based quality gates. You say WHAT, the AI decides HOW.",
  "author": {
    "name": "Dennis Westermann",
    "url": "https://www.dennis-westermann.de"
  },
  "homepage": "https://github.com/cubetribe/ClaudeCode_GodMode-On",
  "repository": "https://github.com/cubetribe/ClaudeCode_GodMode-On",
  "license": "proprietary",
  "keywords": [
    "orchestration",
    "multi-agent",
    "quality-gates",
    "development-workflow",
    "ai-agents",
    "code-quality",
    "automated-testing",
    "self-improving",
    "claude-fable-5",
    "fable-orchestrator",
    "claude-code",
    "subagents",
    "token-efficiency"
  ],
  "agents": [
    "agents/researcher.md",
    "agents/architect.md",
    "agents/api-guardian.md",
    "agents/builder.md",
    "agents/validator.md",
    "agents/tester.md",
    "agents/scribe.md",
    "agents/github-manager.md",
    "agents/security.md",
    "agents/ci-security-guardian.md",
    "agents/docs-dx.md",
    "agents/quality-operations.md",
    "agents/runtime-platform.md",
    "agents/workflow-design.md",
    "agents/workspace-governance.md"
  ],
  "skills": [
    "skills/workflows/SKILL.md",
    "skills/quality-gates/SKILL.md",
    "skills/release/SKILL.md",
    "skills/issue-processing/SKILL.md",
    "skills/api-change/SKILL.md",
    "skills/research/SKILL.md",
    "skills/meta-decisions/SKILL.md",
    "skills/agent-teams/SKILL.md",
    "skills/prototype-mode/SKILL.md",
    "skills/departments/SKILL.md",
    "skills/cost-efficiency/SKILL.md",
    "skills/greenfield-bootstrap/SKILL.md"
  ],
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/session-start.js",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/check-api-impact.js \"$CLAUDE_FILE_PATH\"",
            "timeout": 30
          }
        ]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/validate-agent-output.js",
            "timeout": 30
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node ${CLAUDE_PLUGIN_ROOT}/scripts/validate-agent-output.js",
            "timeout": 30
          }
        ]
      }
    ]
  },
  "mcpServers": {
    "playwright": {
      "command": "npx",
      "args": ["@playwright/mcp@latest"],
      "optional": true
    }
  }
}
