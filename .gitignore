# OS
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Generated Reports (all agent/subagent reports go here)
/reports/
!/reports/.gitkeep

# Legacy Agents folder (for projects using CC_GodMode)
/Agents/
!/Agents/.gitkeep

# Meta-Orchestration Design Work (experimental - separate repos)
/Orchester-Design/

# Agent definitions must be tracked (these are the agent prompts, not reports).
# Re-include the directory too: the legacy /Agents/ rule above shadows the lowercase
# agents/ source dir on case-insensitive filesystems (Windows/macOS), which otherwise
# silently ignores newly added agent files (a file cannot be re-included while its
# parent directory is excluded).
!agents/
!agents/*.md

# Node
node_modules/

# Logs
*.log
npm-debug.log*

# Temporary
*.tmp
*.temp

# Secrets (should never be here anyway)
.env
.env.*
*.pem
*.key
credentials.json
.playwright-mcp/
